{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "advisor-desktop",
  "compatibility_date": "2025-12-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "advisor.joelelewis.com", "custom_domain": true }
  ],
  "workers_dev": true
}
